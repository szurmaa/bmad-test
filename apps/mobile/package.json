    "prebuild": "expo prebuild --no-install",
    "prebuild:clean": "expo prebuild --clean --no-install",
    "build:ios:sim": "PATH=\"$PATH:/Users/aszurma/.rbenv/versions/3.3.0/bin\" expo run:ios --no-bundler",
    "build:android:debug": "expo run:android --no-bundler --device",
    "test:e2e:ios:full": "npm run build:ios:sim && npm run test:e2e:ios",
    "build:ios:sim:18": "PATH=\"$PATH:/Users/aszurma/.rbenv/versions/3.3.0/bin\" IOS_DEPLOYMENT_TARGET=18.6 expo run:ios --no-bundler --device \"iPhone 16 Pro\""
